# ============================================================================
# Coachio Landing Page — example environment. Copy to `.env` and fill real
# values. NEVER commit the real `.env` (already in .gitignore).
#   cp .env.example .env
# ============================================================================

# ---- Core API ----
PROJECT_NAME=Coachio Landing Page              # App display name
API_V1_PREFIX=/api/v1                          # Mount prefix for all v1 routes
DEBUG=False                                     # True only in local dev

# ---- Database (Postgres / Supabase pooler) ----
# Local: postgresql://coachio:coachio@db:5432/coachio
# Vercel/Supabase: postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://coachio:coachio@db:5432/coachio

# ---- Admin auth (JWT) ----
SECRET_KEY=change-me-to-a-long-random-string   # generate: openssl rand -hex 32
ALGORITHM=HS256                                 # JWT signing algorithm
ACCESS_TOKEN_EXPIRE_MINUTES=480                 # Admin token lifetime (minutes)
ADMIN_EMAIL=admin@coachio.local                 # Seed/first admin email

# ---- CORS ----
# Comma-separated or JSON array of allowed web origins.
ALLOWED_ORIGINS=http://localhost:3000

# ---- Frontend URLs (used in emails, SePay callback, success/checkout links) ----
FRONTEND_URL=http://localhost:3000              # Public web base URL
PUBLIC_WEB_BASE_URL=http://localhost:3000       # Base for CAPI event_source_url
PREFIX_URL_CALLBACK=http://localhost:8000/api/v1 # Base for SePay webhook callback build

# ---- SePay / VietQR (payment) ----
SEPAY_BANK_NAME=                                # e.g. OCB, MBBank, VCB (bank short code)
SEPAY_ACCOUNT_NUMBER=                           # Receiving bank account number

# ---- Resend (transactional + broadcast email) ----
RESEND_API_KEY=re_your_resend_api_key_here      # Resend API key
RESEND_FROM_EMAIL=no-reply@example.com          # Verified sender address

# ---- Object storage (S3-compatible) ----
S3_ENDPOINT=https://s3.ap-southeast-1.amazonaws.com
S3_BUCKET_NAME=coachio-local                    # Bucket name
S3_ACCESS_KEY=YOUR_ACCESS_KEY_ID                # Access key id
S3_SECRET_KEY=YOUR_SECRET_ACCESS_KEY            # Secret access key
S3_REGION=ap-southeast-1                        # Region

# ---- Bunny CDN (optional — media delivery) ----
BUNNY_CDN_URL=                                  # Public CDN base URL for stored media
BUNNY_STORAGE_ZONE=                             # Bunny storage zone name
BUNNY_API_KEY=                                  # Bunny storage/API key
BUNNY_PULL_ZONE_URL=                            # Pull zone URL
BUNNY_REGION=                                   # Storage region code (empty = default)

# ---- CDN host rewrite (optional — migrate legacy Bunny hosts to custom CNAME) ----
CDN_LEGACY_HOSTS=                               # Comma-separated legacy CDN hosts to rewrite FROM
CDN_CANONICAL_HOST=                             # Canonical CDN host to rewrite TO; empty = disabled

# ---- Meta Conversions API (optional — funnel tracking defaults) ----
# When BOTH pixel id + token are set, new funnels auto-enable tracking.
META_DEFAULT_PIXEL_ID=                          # Default Meta Pixel id
META_DEFAULT_CAPI_TOKEN=                        # Default CAPI access token
META_DEFAULT_TEST_EVENT_CODE=                   # Optional test event code
META_GRAPH_API_VERSION=v21.0                    # Graph API version
META_PURCHASE_MIN_VND=10000                     # Min VND amount reported as Purchase
IPINFO_TOKEN=                                   # Optional — geo advanced matching

# ---- Landing cache tuning (optional) ----
LANDING_CACHE_ENABLED=True
LANDING_CACHE_TTL=3600                          # Safety-net TTL (seconds)

# ---- Broadcast email worker (optional tuning) ----
BROADCAST_BATCH_SIZE=100
BROADCAST_RATE_DELAY_MS=200
BROADCAST_MAX_ATTEMPTS=3
BROADCAST_STUCK_TIMEOUT_S=300                   # Reaper: requeue 'sending' jobs older than this
BROADCAST_JOB_INTERVAL_SECONDS=5               # Worker loop sleep between ticks

# ============================================================================
# Web build args (NEXT_PUBLIC_* are baked at BUILD time, not runtime).
# docker compose passes these as build args to apps/web/Dockerfile.
# ============================================================================
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000   # Browser-facing API base URL (baked at build time)
API_INTERNAL_URL=http://api:8000                # Server-only (SSR fetch inside compose network); overrides NEXT_PUBLIC_BACKEND_URL on the server
NEXT_PUBLIC_DEFAULT_FUNNEL_SLUG=               # Slug of the funnel the root "/" redirects to (leave empty to show placeholder)
